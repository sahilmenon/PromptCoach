{
  "manifest_version": 3,
  "name": "PromptCoach",
  "version": "0.3.6",
  "description": "Floating prompt coach with live model review, inspect audit, and local transcript tools.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://*.claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PromptCoach",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["lib/promptcoach-core.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/promptcoach-logo.png", "icons/tokenlean-logo.png"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": [
        "dashboard.html",
        "css/dashboard.css",
        "js/dashboard.js",
        "lib/chart.min.js"
      ],
      "matches": ["https://gemini.google.com/*"]
    }
  ]
}
