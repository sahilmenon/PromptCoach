{
  "name": "llmguide",
  "version": "0.1.0",
  "description": "Prompt-efficiency coach for Claude Code and Codex CLI",
  "license": "MIT",
  "bin": {
    "llmguide": "bin/llmguide.js"
  },
  "main": "dist/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zackkzz/csesoc_flagship_hackathon.git"
  },
  "homepage": "https://github.com/Zackkzz/csesoc_flagship_hackathon#readme",
  "bugs": {
    "url": "https://github.com/Zackkzz/csesoc_flagship_hackathon/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.cjs",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "extension:check": "node --check extension/background.js && node --check extension/content.js && node -e \"JSON.parse(require('fs').readFileSync('extension/manifest.json','utf8'))\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs/cli/ASSUMPTIONS.md",
    "LICENSE",
    "extension",
    ".env.example"
  ],
  "keywords": [
    "claude-code",
    "codex",
    "llm",
    "prompt-engineering",
    "tokens",
    "efficiency",
    "sustainability",
    "subscription"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
