# Copy to .env and fill in one provider key.
# Existing shell exports still override these values.
# `llmguide config set-key` can also save an Anthropic key under ~/.llmguide/.

# Google Gemini (free tier: https://aistudio.google.com/app/apikey)
TOKENLEAN_LLM_PROVIDER=gemini
GEMINI_API_KEY=
TOKENLEAN_LLM_MODEL=gemini-2.5-flash

# Or Anthropic Haiku:
# TOKENLEAN_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# TOKENLEAN_LLM_MODEL=claude-haiku-4-5
# LLMGUIDE_LLM_* aliases are also accepted.

# Or OpenAI:
# TOKENLEAN_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# TOKENLEAN_LLM_MODEL=gpt-5.4-nano

# Or Cursor:
# TOKENLEAN_LLM_PROVIDER=cursor
# CURSOR_API_KEY=
# TOKENLEAN_LLM_MODEL=composer-2.5
